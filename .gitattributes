# Default: normalize line endings to LF in the repo
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks the shebang on Linux
*.sh text eol=lf

# Python and Lua scripts — LF only
*.py text eol=lf
*.lua text eol=lf

# Config / param files — LF only
*.param text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.bin binary
